# =============================================================================
# App Base URL
# =============================================================================
# Used for OAuth redirect URIs and API origin resolution.
# Set to your deployed domain in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =============================================================================
# MongoDB
# =============================================================================
# Your MongoDB connection string.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# =============================================================================
# Firebase (Client-side + Server-side)
# =============================================================================
# Required for Firebase Auth, Firestore, and Storage.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# Cloudinary (Video/Image Uploads)
# =============================================================================
# Required for large video uploads, shorts generation, and Instagram posting.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=your_server_upload_preset

# =============================================================================
# YouTube OAuth (Optional — for YouTube account linking)
# =============================================================================
# Create credentials at https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# =============================================================================
# YouTube Download Cookies (Optional — for bot-check bypass)
# =============================================================================
# Use these ONLY if YouTube repeatedly blocks video downloads with
# "Sign in to confirm you're not a bot". See YOUTUBE_SETUP.md for export steps.
#
# Option A: Path to a Netscape cookies.txt file on the server filesystem
YOUTUBE_COOKIES_FILE=
#
# Option B: Base64-encoded contents of a Netscape cookies.txt file
YOUTUBE_COOKIES_BASE64=
#
# Option C: Inline cookie string (less common)
YOUTUBE_COOKIES=

# =============================================================================
# Facebook / Meta (Optional — for Instagram account linking)
# =============================================================================
# Create app at https://developers.facebook.com/apps
NEXT_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id

